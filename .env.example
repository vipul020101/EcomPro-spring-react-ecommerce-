# Backend
JWT_SECRET=change-me-to-a-long-random-secret-32chars-min

# Postgres (when using docker compose)
DB_URL=jdbc:postgresql://localhost:5432/ecom
DB_DRIVER=org.postgresql.Driver
DB_USER=ecom
DB_PASSWORD=ecom
FLYWAY_ENABLED=true
JPA_DDL_AUTO=validate
H2_CONSOLE_ENABLED=false

# Seeded admin user
SEED_ADMIN_EMAIL=admin@ecom.local
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_NAME=Admin